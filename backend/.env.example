# Flask Configuration
SECRET_KEY=your-secret-key-here-change-in-production
FLASK_ENV=production

# Database Configuration
# For SQLite (simple, single file):
DATABASE_URL=sqlite:////var/www/atk_transit/data/atk_transit.db

# For PostgreSQL (recommended for production):
# DATABASE_URL=postgresql://username:password@localhost/atk_transit

# Server Configuration
FLASK_HOST=0.0.0.0
FLASK_PORT=5555

# CORS Origins (comma-separated)
CORS_ORIGINS=http://abiteam.tech,https://abiteam.tech,http://www.abiteam.tech,https://www.abiteam.tech,http://abiteam.tech/projects/ATK,https://abiteam.tech/projects/ATK
